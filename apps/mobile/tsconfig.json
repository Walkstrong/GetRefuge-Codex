{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "experimentalDecorators": true,
    "paths": {
      "@getrefuge/crypto": [
        "../../packages/crypto/src/index.ts"
      ],
      "@getrefuge/shared-schema": [
        "../../packages/shared-schema/src/index.ts"
      ],
      "@getrefuge/sync": [
        "../../packages/sync/src/index.ts"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
